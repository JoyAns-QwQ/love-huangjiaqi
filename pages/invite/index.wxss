.container {
  padding: 20px;
  font-size: 14px;
}

.calendar-list {
  margin-bottom: 20px;
}

.calendar-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px;
  border: 1px solid #eee;
  border-radius: 4px;
  margin-bottom: 10px;
}

.calendar-item.selected {
  border-color: #1aad19;
  background-color: #f0f9eb;
}

.calendar-name {
  flex: 1;
}

.calendar-actions {
  display: flex;
  gap: 10px;
}

.invite-code {
  margin-top: 20px;
  padding: 15px;
  border: 1px solid #eee;
  border-radius: 4px;
  text-align: center;
  font-size: 16px;
  font-weight: bold;
}

.scan-button {
  margin-top: 20px;
}

.scan-button button {
  width: 100%;
  padding: 10px;
  background-color: #1aad19;
  color: white;
  border: none;
  border-radius: 4px;
  font-size: 16px;
}

.scan-button button:active {
  background-color: #179b16;
}

.accept-button {
  margin-top: 20px;
}

.accept-button button {
  width: 100%;
  padding: 10px;
  background-color: #1aad19;
  color: white;
  border: none;
  border-radius: 4px;
  font-size: 16px;
}

.accept-button button:active {
  background-color: #179b16;
}

.scan-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.scan-content {
  background-color: white;
  padding: 20px;
  border-radius: 4px;
  width: 80%;
}

.scan-content h3 {
  margin-top: 0;
}

.scan-content input {
  width: 100%;
  padding: 10px;
  margin: 10px 0;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 16px;
}

.scan-content button {
  width: 100%;
  padding: 10px;
  background-color: #1aad19;
  color: white;
  border: none;
  border-radius: 4px;
  font-size: 16px;
}

.scan-content button:active {
  background-color: #179b16;
}

.scan-content .close-button {
  background-color: #ff4d4f;
}

.scan-content .close-button:active {
  background-color: #ff7875;
}
