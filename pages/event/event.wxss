/* 页面样式 */
page {
  background-color: #f5f5f5;
  padding-bottom: 30rpx;
  transition: background-color 0.3s ease;
}

/* 表单样式 */
.form-group {
  margin-bottom: 24rpx;
  animation: fadeIn 0.5s ease;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
  color: #374151;
  font-size: 28rpx;
}

/* 选择器样式 */
.picker {
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background-color: #fff;
  padding: 16rpx;
  transition: all 0.2s ease;
}

.picker flex-1 {
  font-size: 28rpx;
}

.picker:active {
  background-color: #f9fafb;
}

/* 颜色预览 */
.color-preview {
  width: 30rpx;
  height: 30rpx;
  border-radius: 4rpx;
  border: 1rpx solid #e5e7eb;
  transition: transform 0.2s ease;
}

/* 按钮样式 */
.submit-button {
  margin-top: 40rpx;
  animation: slideUp 0.5s ease 0.3s both;
}

.submit-button button {
  font-size: 28rpx;
  padding: 16rpx 0;
  transition: all 0.2s ease;
}

.submit-button button:active {
  transform: scale(0.95);
  background-color: #4090ff;
}

/* 动画定义 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
