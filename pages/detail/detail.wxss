.container {
  padding: 20px;
}

.header {
  text-align: center;
  padding: 20px 0;
  font-size: 20px;
  font-weight: bold;
  border-bottom: 1px solid #eee;
}

.event-info {
  margin-top: 20px;
}

.event-title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 10px;
}

.event-calendar {
  color: #666;
  margin-bottom: 20px;
}

.event-time {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15px;
}

.event-time text {
  font-size: 16px;
}

.event-location, .event-description {
  margin-bottom: 15px;
}

.event-description text {
  display: block;
  margin-bottom: 5px;
}

.event-color {
  display: flex;
  align-items: center;
  margin-bottom: 20px;
}

.color-preview {
  width: 30px;
  height: 30px;
  border-radius: 4px;
  border: 1px solid #ddd;
  margin-left: 10px;
}

.event-actions {
  display: flex;
  gap: 20px;
  margin-top: 30px;
}

.edit-button, .delete-button {
  flex: 1;
  padding: 15px;
  border-radius: 4px;
  font-size: 16px;
}

.edit-button {
  background-color: #1aad19;
  color: white;
}

.edit-button:active {
  background-color: #179b16;
}

.delete-button {
  background-color: #ff4d4f;
  color: white;
}

.delete-button:active {
  background-color: #ff7875;
}
