<view class="container">
  <view class="header">
    <text>事件详情</text>
  </view>

  <view class="event-info">
    <view class="event-title">{{event.title}}</view>
    <view class="event-calendar">{{calendarName}}</view>
    
    <view class="event-time">
      <text>开始时间：{{event.startTime}}</text>
      <text wx:if="{{!event.isAllDay}}">结束时间：{{event.endTime}}</text>
    </view>

    <view class="event-location" wx:if="{{event.location}}">
      <text>地点：{{event.location}}</text>
    </view>

    <view class="event-description" wx:if="{{event.description}}">
      <text>描述：</text>
      <text>{{event.description}}</text>
    </view>

    <view class="event-color">
      <text>颜色：</text>
      <view class="color-preview" style="background-color: {{event.color}}"></view>
    </view>
  </view>

  <view class="event-actions">
    <button class="edit-button" bindtap="onEdit">编辑</button>
    <button class="delete-button" bindtap="onDelete">删除</button>
  </view>
</view>
