.container {
  padding: 20px;
}

.header {
  text-align: center;
  padding: 20px 0;
  font-size: 20px;
  font-weight: bold;
  border-bottom: 1px solid #eee;
}

.calendars-section, .events-section {
  margin-top: 20px;
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 15px;
  padding-bottom: 10px;
  border-bottom: 1px solid #eee;
}

.calendar-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px;
  border: 1px solid #eee;
  border-radius: 4px;
  margin-bottom: 10px;
  background-color: white;
}

.calendar-info {
  display: flex;
  align-items: center;
  gap: 10px;
}

.calendar-name {
  font-weight: bold;
}

.calendar-color {
  width: 20px;
  height: 20px;
  border-radius: 4px;
}

.calendar-stats {
  color: #666;
  font-size: 14px;
}

.add-calendar-button {
  text-align: center;
  margin-top: 20px;
}

.add-calendar-button button {
  background-color: #1aad19;
  color: white;
  border: none;
  border-radius: 4px;
  padding: 10px 20px;
  font-size: 16px;
}

.add-calendar-button button:active {
  background-color: #179b16;
}

.event-item {
  padding: 15px;
  border: 1px solid #eee;
  border-radius: 4px;
  margin-bottom: 10px;
  background-color: white;
}

.event-title {
  font-weight: bold;
  margin-bottom: 5px;
}

.event-time {
  color: #666;
  font-size: 14px;
}
