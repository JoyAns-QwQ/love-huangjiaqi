.container {
  padding: 20px;
  font-size: 14px;
}

.member-list {
  margin-bottom: 20px;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px;
  border: 1px solid #eee;
  border-radius: 4px;
  margin-bottom: 10px;
}

.member-info {
  flex: 1;
}

.member-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  margin-right: 10px;
}

.member-details {
  flex: 3;
}

.member-name {
  font-weight: bold;
  margin-bottom: 5px;
}

.member-permission {
  color: #999;
  font-size: 12px;
}

.remove-button {
  background-color: #ff4d4f;
  color: white;
  border: none;
  border-radius: 4px;
  padding: 5px 10px;
  font-size: 12px;
}

.remove-button:active {
  background-color: #ff7875;
}

.calendar-info {
  margin-top: 20px;
  padding: 15px;
  border: 1px solid #eee;
  border-radius: 4px;
}

.calendar-name {
  font-weight: bold;
  margin-bottom: 10px;
}

.calendar-actions {
  margin-top: 20px;
}

.back-button {
  background-color: #1aad19;
  color: white;
  border: none;
  border-radius: 4px;
  padding: 10px;
  width: 100%;
  font-size: 16px;
}

.back-button:active {
  background-color: #179b16;
}
