page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 布局类 */
.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 30rpx;
}

.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.gap-2 {
  gap: 8rpx;
}

.gap-4 {
  gap: 16rpx;
}

.gap-6 {
  gap: 24rpx;
}

/* 间距类 */
.p-2 {
  padding: 8rpx;
}

.p-4 {
  padding: 16rpx;
}

.p-6 {
  padding: 24rpx;
}

.px-3 {
  padding-left: 12rpx;
  padding-right: 12rpx;
}

.py-2 {
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.m-2 {
  margin: 8rpx;
}

.m-4 {
  margin: 16rpx;
}

/* 颜色类 */
.bg-white {
  background-color: #fff;
}

.bg-gray-50 {
  background-color: #f9fafb;
}

.bg-gray-100 {
  background-color: #f3f4f6;
}

.bg-blue-500 {
  background-color: #1677ff;
}

.bg-blue-600 {
  background-color: #4090ff;
}

.text-white {
  color: #fff;
}

.text-gray-800 {
  color: #1f2937;
}

.text-gray-600 {
  color: #6b7280;
}

.text-gray-400 {
  color: #9ca3af;
}

/* 按钮类 */
.btn {
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  border: none;
  cursor: pointer;
}

.btn-primary {
  background-color: #1677ff;
  color: #fff;
}

.btn-primary:active {
  background-color: #4090ff;
}

.btn-default {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #d9d9d9;
}

/* 输入框类 */
.input {
  background-color: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #e5e7eb;
}

/* 文本类 */
.text-sm {
  font-size: 24rpx;
}

.text-base {
  font-size: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.font-bold {
  font-weight: bold;
}

/* 空状态类 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 卡片类 */
.card {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.card-header {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-body {
  padding: 20rpx;
}

/* 表单类 */
.form-group {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
  color: #374151;
}

/* 动画类 */
.fade-in {
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 日历相关样式 */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background-color: #fff;
  position: relative;
  cursor: pointer;
}

.calendar-day.other-month {
  color: #9ca3af;
  background-color: #f9fafb;
}

.calendar-day.today {
  background-color: #e6f7ff;
}

.event-dot {
  position: absolute;
  bottom: 4rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background-color: #1677ff;
}
