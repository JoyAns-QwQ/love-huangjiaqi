/* 日历组件样式 */
.calendar-container {
  margin-top: 20rpx;
}

.calendar-header {
  margin-bottom: 20rpx;
}

.calendar-weekdays {
  font-size: 24rpx;
  color: #6b7280;
}

.calendar-day {
  aspect-ratio: 1;
  font-size: 24rpx;
  color: #374151;
  position: relative;
}

.calendar-day.today {
  color: #1677ff;
  font-weight: bold;
}

.calendar-day.other-month {
  color: #9ca3af;
}

.event-dot {
  position: absolute;
  bottom: 4rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background-color: #1677ff;
}
